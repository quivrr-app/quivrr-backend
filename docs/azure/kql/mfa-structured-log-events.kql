ContainerAppConsoleLogs_CL
| extend payload = parse_json(Log_s)
| where tostring(payload.service) == "manufacturer_availability"
| project TimeGenerated, event=tostring(payload.event), region=tostring(payload.region), brand=tostring(payload.brand), status=tostring(payload.status), rows=tolong(payload.rows), linked_model_rows=tolong(payload.linked_model_rows), linked_size_rows=tolong(payload.linked_size_rows)
| order by TimeGenerated desc
