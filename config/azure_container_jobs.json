{
  "jobs": [
    {
      "jobName": "quivrr-weekly-brand-catalogues",
      "jobType": "catalogue",
      "schedule": "0 3 * * 1",
      "expectedRegion": "GLOBAL",
      "regions": ["AU", "EU", "ID", "US"],
      "stateFile": "weekly_brand_catalogues",
      "structuredLogEventName": "catalogue_refresh_completed",
      "freshnessHours": 168,
      "metricSource": "catalogue",
      "entryScript": "python scripts/run_all_brand_catalogues.py",
      "contractLayer": "global_canonical",
      "readsTables": ["Brands", "BoardModels", "BoardSizes"],
      "writesTables": ["Brands", "BoardModels", "BoardSizes"],
      "writesFields": [
        "BrandName",
        "ModelName",
        "ModelFamily",
        "BoardCategory",
        "OfficialProductUrl",
        "OfficialImageUrl",
        "Description",
        "Construction",
        "LengthFeetInches",
        "Width",
        "Thickness",
        "VolumeLitres",
        "FinSetup",
        "TailShape",
        "IsActive"
      ],
      "expectedSourceOutputs": [
        "scrapers/brands/*/output/*_master_catalogue*.json",
        "scrapers/brands/output/weekly_brand_catalogue_report.json"
      ]
    },
